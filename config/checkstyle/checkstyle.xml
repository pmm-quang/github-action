<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <!-- Mã nguồn UTF-8 -->
    <property name="charset" value="UTF-8"/>

    <!-- Không cho phép tab, luôn dùng space -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

    <!-- Bắt buộc có newline ở cuối file -->
    <module name="NewlineAtEndOfFile"/>

    <!-- Giới hạn độ dài 1 dòng (phải nằm ngoài TreeWalker) -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern"
                  value="^package|^import|a href|href|http://|https://"/>
    </module>

    <module name="TreeWalker">
        <!-- Tên class trùng với tên file -->
        <module name="OuterTypeFilename"/>

        <!-- Quy tắc indent 4 spaces -->
        <module name="Indentation">
            <property name="basicOffset" value="4"/>
            <property name="braceAdjustment" value="0"/>
            <property name="caseIndent" value="4"/>
            <property name="tabWidth" value="4"/>
        </module>

        <!-- Luôn dùng ngoặc nhọn cho if/for/while -->
        <module name="NeedBraces"/>

        <!-- Chỉ cho phép catch rỗng với biến tên ignored/expected -->
        <module name="EmptyCatchBlock">
            <property name="exceptionVariableName" value="ignored|expected"/>
        </module>

        <!-- Quy tắc đặt tên -->
        <module name="TypeName"/>
        <module name="MethodName"/>
        <module name="ParameterName"/>
        <module name="LocalVariableName"/>
        <module name="MemberName"/>
    </module>

</module>

